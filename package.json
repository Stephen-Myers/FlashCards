{
  "name": "flash-cards-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "expo": "~54.0.33"
  },
  "scripts": {
    "dev": "npm run dev:mobile",
    "dev:web": "npm run dev -w @flashcards/web",
    "dev:mobile": "npm run start -w @flashcards/mobile",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces"
  }
}
